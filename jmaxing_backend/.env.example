# J-MAXING Backend Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=J-MAXING
ENVIRONMENT=development  # development, staging, production
DEBUG=True
API_VERSION=v1

# Database
DATABASE_URL=postgresql://jmaxing:jmaxing_password@localhost:5432/jmaxing
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Frontend URLs
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FRONTEND_URL=http://localhost:5173

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp","image/gif"]
ALLOWED_VIDEO_TYPES=["video/mp4","video/webm","video/quicktime"]
ALLOWED_AUDIO_TYPES=["audio/mpeg","audio/wav","audio/ogg"]

# Storage Service
STORAGE_PROVIDER=local  # local, s3, cloudinary

# AWS S3 (if using S3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=  # For MinIO or other S3-compatible

# Cloudinary (if using Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI/ML Features
AI_CATEGORIZATION_ENABLED=False
AI_MODEL_PATH=./models
AI_CONFIDENCE_THRESHOLD=0.7

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@jmaxing.com

# Redis (Optional - for caching and real-time)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/jmaxing.log

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Referral System
REFERRER_REWARD=100.00  # JC reward for referrer
REFERRED_REWARD=50.00   # JC reward for referred user
